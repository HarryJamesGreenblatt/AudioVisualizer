<Window x:Class="AudioVisualizer.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
        xmlns:local="clr-namespace:AudioVisualizer"
        mc:Ignorable="d"
        Title="Audio Visualizer" Height="400" Width="900"
        Background="Black" Closing="Window_Closing">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <local:VisualizerElement x:Name="Visualizer" Grid.Row="0" />

        <StackPanel Grid.Row="1" Orientation="Horizontal"
                    HorizontalAlignment="Center" VerticalAlignment="Center"
                    Margin="0,6,0,6">
            <Button x:Name="StartStopButton" Content="Start"
                    Foreground="White" Background="#333333"
                    Width="80" Margin="8,0"
                    Click="StartStopButton_Click" />

            <ui:ToggleSwitch x:Name="RainToggle" Content="Rain"
                             IsChecked="True" Margin="8,0"
                             Checked="RainToggle_Changed" Unchecked="RainToggle_Changed" />

            <ui:ToggleSwitch x:Name="BallToggle" Content="Ball"
                             IsChecked="True" Margin="8,0"
                             Checked="BallToggle_Changed" Unchecked="BallToggle_Changed" />
        </StackPanel>
    </Grid>
</Window>

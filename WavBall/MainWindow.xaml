<Window x:Class="WavBall.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
        xmlns:shell="clr-namespace:System.Windows.Shell;assembly=PresentationFramework"
        xmlns:local="clr-namespace:WavBall"
        mc:Ignorable="d"
        Title="Windows WavBall" Height="400" Width="900"
        Icon="Assets/Images/Icon.ico"
        Background="Black"
        WindowStyle="None"
        ResizeMode="CanResize"
        StateChanged="Window_StateChanged"
        Closing="Window_Closing">
    <shell:WindowChrome.WindowChrome>
        <shell:WindowChrome CaptionHeight="36"
                            ResizeBorderThickness="6"
                            GlassFrameThickness="0"
                            UseAeroCaptionButtons="False"
                            CornerRadius="0" />
    </shell:WindowChrome.WindowChrome>

    <!-- Outer chassis: thin dark frame around the whole shell (Corona-style chrome edge).
         Margin compensates for the maximized-state overflow Windows applies to WindowChrome'd
         windows (otherwise the chrome bleeds 7px off-screen). Adjusted by Window_StateChanged. -->
    <Border x:Name="OuterChassis"
            BorderBrush="{StaticResource WmpChromeShadowBrush}"
            BorderThickness="1"
            CornerRadius="6"
            Background="{StaticResource WmpChromeVerticalBrush}"
            ClipToBounds="True">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="36" />   <!-- svTop: LED display panel embedded in chrome -->
            <RowDefinition Height="*"  />   <!-- svMiddle: visualizer in inset bezel + metadata strip -->
            <RowDefinition Height="60" />   <!-- transport chrome panel (equalizer_*) -->
        </Grid.RowDefinitions>

        <!-- ===== svTop: title bar + LED display + window controls (we OWN the chrome now) =====
             Whole strip is draggable by WindowChrome (CaptionHeight=36). Interactive children
             opt out via WindowChrome.IsHitTestVisibleInChrome="True". -->
        <Border Grid.Row="0"
                BorderBrush="{StaticResource WmpChromeShadowBrush}"
                BorderThickness="0,0,0,1"
                Padding="6,3,0,3">
            <!-- Grey metallic chrome matching the transport panel's button surround
                 (equalizer_left.png y=0-2 + y=16-21: glassy highlight → grey-blue → light transition). -->
            <Border.Background>
                <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                    <GradientStop Color="#FFEBF7FB" Offset="0.0"/>
                    <GradientStop Color="#FF8C97B9" Offset="0.15"/>
                    <GradientStop Color="#FF909CBC" Offset="0.35"/>
                    <GradientStop Color="#FFA0AACB" Offset="0.55"/>
                    <GradientStop Color="#FFDDE6F5" Offset="0.80"/>
                    <GradientStop Color="#FFC3DBF0" Offset="0.92"/>
                    <GradientStop Color="#FF9CB0D7" Offset="1.0"/>
                </LinearGradientBrush>
            </Border.Background>
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />  <!-- App icon + title -->
                    <ColumnDefinition Width="*"    />  <!-- LED panel -->
                    <ColumnDefinition Width="Auto" />  <!-- Min / Max / Close -->
                </Grid.ColumnDefinitions>

                <!-- Icon + brand mark -->
                <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center" Margin="2,0,8,0">
                    <Image Source="Assets/Images/Icon.png" Width="16" Height="16" Margin="0,0,6,0"
                           RenderOptions.BitmapScalingMode="HighQuality"/>
                    <TextBlock Text="Windows WavBall"
                               FontFamily="{StaticResource WmpChromeFontFamily}"
                               FontSize="11" FontWeight="Bold"
                               Foreground="{StaticResource WmpBodyTextBrush}"
                               VerticalAlignment="Center"/>
                </StackPanel>

                <!-- Col 1: drag region (spacer — timer lives in side panel) -->

                <!-- Window control buttons -->
                <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Stretch">
                    <Button x:Name="MinimizeButton"
                            Style="{StaticResource WmpWindowButtonStyle}"
                            ToolTip="Minimize"
                            Click="MinimizeButton_Click"
                            shell:WindowChrome.IsHitTestVisibleInChrome="True">
                        <Path Data="{StaticResource WmpMinimizeGeometry}"
                              Stroke="{StaticResource WmpBodyTextBrush}"
                              StrokeThickness="1"
                              Width="10" Height="10"/>
                    </Button>
                    <Button x:Name="MaximizeButton"
                            Style="{StaticResource WmpWindowButtonStyle}"
                            ToolTip="Maximize"
                            Click="MaximizeButton_Click"
                            shell:WindowChrome.IsHitTestVisibleInChrome="True">
                        <Path x:Name="MaximizeGlyph"
                              Data="{StaticResource WmpMaximizeGeometry}"
                              Stroke="{StaticResource WmpBodyTextBrush}"
                              StrokeThickness="1"
                              Width="10" Height="10"/>
                    </Button>
                    <Button x:Name="CloseButton"
                            Style="{StaticResource WmpCloseButtonStyle}"
                            ToolTip="Close"
                            Click="CloseButton_Click"
                            shell:WindowChrome.IsHitTestVisibleInChrome="True">
                        <Path Data="{StaticResource WmpCloseGeometry}"
                              Stroke="{StaticResource WmpBodyTextBrush}"
                              StrokeThickness="1"
                              Width="10" Height="10"/>
                    </Button>
                </StackPanel>
            </Grid>
        </Border>

        <!-- ===== svMiddle: visualizer (left) + ball-data side panel (right, WMP9-style) ===== -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>    <!-- Visualizer with inner chrome frame -->
                <ColumnDefinition Width="220"/>  <!-- Side panel -->
            </Grid.ColumnDefinitions>

            <!-- Visualizer wrapped in WMP9 inner chrome frame -->
            <Grid Grid.Column="0">
                <!-- Left chrome edge: blue metallic gradient matching the transport panel
                     chrome (equalizer_middle.png), rotated 90° for vertical use.
                     Gradient: light glassy highlight on outer edge → deep WMP9 blue → dark inner edge. -->
                <Border Width="19" HorizontalAlignment="Left" Panel.ZIndex="1">
                    <Border.Background>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                            <GradientStop Color="#FFE9EDF6" Offset="0.0"/>
                            <GradientStop Color="#FFCFDCF1" Offset="0.05"/>
                            <GradientStop Color="#FF5160A6" Offset="0.15"/>
                            <GradientStop Color="#FF6C7DBE" Offset="0.4"/>
                            <GradientStop Color="#FF8BA0D3" Offset="0.6"/>
                            <GradientStop Color="#FF9EB6E0" Offset="0.8"/>
                            <GradientStop Color="#FF8396BB" Offset="0.92"/>
                            <GradientStop Color="#FF646871" Offset="1.0"/>
                        </LinearGradientBrush>
                    </Border.Background>
                </Border>

                <!-- Right bevel: metallic separator between viz and side panel -->
                <Border Width="7" HorizontalAlignment="Right" Panel.ZIndex="1">
                    <Border.Background>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                            <GradientStop Color="#FF606381" Offset="0.0"/>
                            <GradientStop Color="#FFA0B5D4" Offset="0.5"/>
                            <GradientStop Color="#FFC0D0E8" Offset="1.0"/>
                        </LinearGradientBrush>
                    </Border.Background>
                </Border>

                <!-- Black visualizer area, inset by rail widths + metadata strip height -->
                <Border Background="Black" Margin="19,0,7,23">
                    <local:VisualizerElement x:Name="Visualizer" />
                </Border>

                <!-- Metadata strip at bottom of inner frame (player_bottom_left/middle/right) -->
                <Grid Height="23" VerticalAlignment="Bottom" Panel.ZIndex="1">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <Image Grid.Column="0"
                           Source="pack://application:,,,/Assets/Sprites/bottom_left.png"
                           Width="286" Height="23" Stretch="None" HorizontalAlignment="Left"
                           RenderOptions.BitmapScalingMode="NearestNeighbor"/>
                    <Rectangle Grid.Column="1" Height="23">
                        <Rectangle.Fill>
                            <ImageBrush ImageSource="pack://application:,,,/Assets/Sprites/bottom_middle.png"
                                        TileMode="Tile" ViewportUnits="Absolute"
                                        Viewport="0,0,1,23" Stretch="Fill"/>
                        </Rectangle.Fill>
                    </Rectangle>
                    <Image Grid.Column="2"
                           Source="pack://application:,,,/Assets/Sprites/bottom_right.png"
                           Width="59" Height="23" Stretch="None" HorizontalAlignment="Right"
                           RenderOptions.BitmapScalingMode="NearestNeighbor"/>
                    <TextBlock x:Name="MetadataText"
                               Grid.Column="0" Margin="63,3,0,0"
                               Foreground="#FF00FF00" FontFamily="Arial" FontSize="9" FontWeight="Bold"
                               VerticalAlignment="Top" TextTrimming="CharacterEllipsis"
                               IsHitTestVisible="False"/>
                </Grid>
            </Grid>

            <!-- Side panel: ball stats, timer, round history -->
            <Grid Grid.Column="1">
                <!-- Right bevel: metallic edge on outer side of panel (mirrors viz/panel separator) -->
                <Border Width="7" HorizontalAlignment="Right" Panel.ZIndex="1">
                    <Border.Background>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                            <GradientStop Color="#FFC0D0E8" Offset="0.0"/>
                            <GradientStop Color="#FFA0B5D4" Offset="0.5"/>
                            <GradientStop Color="#FF606381" Offset="1.0"/>
                        </LinearGradientBrush>
                    </Border.Background>
                </Border>
            <Border Background="#FF0D1828"
                    BorderBrush="{StaticResource WmpChromeShadowBrush}"
                    BorderThickness="1,0,7,0"
                    ClipToBounds="True">
                <DockPanel>

                    <!-- ① Header -->
                    <Border DockPanel.Dock="Top" Background="#FF1C3050" Padding="8,5">
                        <TextBlock Text="Ball Info"
                                   Foreground="#FF90C4E8"
                                   FontFamily="{StaticResource WmpChromeFontFamily}"
                                   FontSize="11" FontWeight="Bold"
                                   HorizontalAlignment="Center"/>
                    </Border>

                    <!-- ② Ball icon + name + stage (like album-art area) -->
                    <Border DockPanel.Dock="Top" Padding="10,10,10,6">
                        <StackPanel HorizontalAlignment="Center">
                            <Border Width="80" Height="80"
                                    Background="#FF0A1528"
                                    BorderBrush="#FF2A4878"
                                    BorderThickness="1"
                                    HorizontalAlignment="Center"
                                    Margin="0,0,0,6">
                                <Image x:Name="BallIcon"
                                       Source="Assets/Generated/beach-ball.png"
                                       Width="60" Height="60"
                                       RenderOptions.BitmapScalingMode="HighQuality"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center"/>
                            </Border>
                            <TextBlock x:Name="BallNameDisplay"
                                       Text="Beach Ball"
                                       Foreground="White"
                                       FontFamily="{StaticResource WmpChromeFontFamily}"
                                       FontSize="12" FontWeight="Bold"
                                       HorizontalAlignment="Center"
                                       Margin="0,0,0,2"/>
                        </StackPanel>
                    </Border>

                    <!-- ③ Ball physics stats -->
                    <Border DockPanel.Dock="Top"
                            Background="#FF0A1020"
                            Padding="10,6"
                            Margin="0,0,0,0">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>
                            <TextBlock Grid.Row="0" Grid.Column="0" Text="Mass"
                                       Foreground="#FF5A8AB0" FontSize="10"
                                       FontFamily="{StaticResource WmpChromeFontFamily}" Margin="0,2"/>
                            <TextBlock x:Name="StatMass" Grid.Row="0" Grid.Column="1"
                                       Text="—" Foreground="#FFCCE0F0" FontSize="10"
                                       FontFamily="{StaticResource WmpReadoutFontFamily}"/>
                            <TextBlock Grid.Row="1" Grid.Column="0" Text="Restitution"
                                       Foreground="#FF5A8AB0" FontSize="10"
                                       FontFamily="{StaticResource WmpChromeFontFamily}" Margin="0,2"/>
                            <TextBlock x:Name="StatRestitution" Grid.Row="1" Grid.Column="1"
                                       Text="—" Foreground="#FFCCE0F0" FontSize="10"
                                       FontFamily="{StaticResource WmpReadoutFontFamily}"/>
                            <TextBlock Grid.Row="2" Grid.Column="0" Text="Radius"
                                       Foreground="#FF5A8AB0" FontSize="10"
                                       FontFamily="{StaticResource WmpChromeFontFamily}" Margin="0,2"/>
                            <TextBlock x:Name="StatRadius" Grid.Row="2" Grid.Column="1"
                                       Text="—" Foreground="#FFCCE0F0" FontSize="10"
                                       FontFamily="{StaticResource WmpReadoutFontFamily}"/>
                        </Grid>
                    </Border>

                    <!-- ⑤ Timer header + LED readout (full-width, matching section headers) -->
                    <Border DockPanel.Dock="Top" Background="#FF1C3050" Padding="8,4">
                        <TextBlock Text="Timer"
                                   Foreground="#FF90C4E8"
                                   FontFamily="{StaticResource WmpChromeFontFamily}"
                                   FontSize="10" FontWeight="Bold"
                                   HorizontalAlignment="Center"/>
                    </Border>
                    <Border DockPanel.Dock="Top"
                            Background="#FF000000"
                            Padding="8,5"
                            Margin="0,0,0,4">
                        <TextBlock x:Name="TimerDisplay"
                                   Text="● READY"
                                   Foreground="#FF00FF00"
                                   FontFamily="{StaticResource WmpReadoutFontFamily}"
                                   FontSize="14" FontWeight="Bold"
                                   HorizontalAlignment="Center"/>
                    </Border>

                    <!-- ⑥ Round history header -->
                    <Border DockPanel.Dock="Top" Background="#FF1C3050" Padding="8,4">
                        <TextBlock Text="Round History"
                                   Foreground="#FF90C4E8"
                                   FontFamily="{StaticResource WmpChromeFontFamily}"
                                   FontSize="10" FontWeight="Bold"
                                   HorizontalAlignment="Center"/>
                    </Border>

                    <!-- ④ Now Playing — anchored to bottom, hidden when no session is active -->
                    <StackPanel DockPanel.Dock="Bottom">
                        <Border x:Name="NowPlayingHeader"
                                Background="#FF1C3050"
                                Padding="8,5"
                                Visibility="Collapsed">
                            <TextBlock Text="Now Playing"
                                       Foreground="#FF90C4E8"
                                       FontFamily="{StaticResource WmpChromeFontFamily}"
                                       FontSize="11" FontWeight="Bold"
                                       HorizontalAlignment="Center"/>
                        </Border>
                        <Border x:Name="NowPlayingContent"
                                Background="#FF0A1020"
                                Padding="8,6"
                                Visibility="Collapsed">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <!-- Composite square: app icon underneath, album art on top -->
                                <Border Grid.Column="0"
                                        Width="48" Height="48"
                                        Background="#FF0D1828"
                                        BorderBrush="#FF2A4878"
                                        BorderThickness="1"
                                        ClipToBounds="True"
                                        Margin="0,0,8,0">
                                    <Grid>
                                        <Image x:Name="NowPlayingAppIcon"
                                               RenderOptions.BitmapScalingMode="HighQuality"
                                               Stretch="UniformToFill"/>
                                        <Image x:Name="NowPlayingAlbumArt"
                                               RenderOptions.BitmapScalingMode="HighQuality"
                                               Stretch="UniformToFill"/>
                                    </Grid>
                                </Border>
                                <!-- Track text -->
                                <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                    <TextBlock x:Name="NowPlayingApp"
                                               Foreground="#FF5A8AB0"
                                               FontFamily="{StaticResource WmpChromeFontFamily}"
                                               FontSize="9"
                                               TextTrimming="CharacterEllipsis"/>
                                    <TextBlock x:Name="NowPlayingTitle"
                                               Foreground="White"
                                               FontFamily="{StaticResource WmpChromeFontFamily}"
                                               FontSize="10" FontWeight="Bold"
                                               TextTrimming="CharacterEllipsis"
                                               Margin="0,2,0,0"/>
                                    <TextBlock x:Name="NowPlayingArtist"
                                               Foreground="#FF90C4E8"
                                               FontFamily="{StaticResource WmpChromeFontFamily}"
                                               FontSize="9"
                                               TextTrimming="CharacterEllipsis"/>
                                </StackPanel>
                            </Grid>
                        </Border>
                    </StackPanel>

                    <!-- ⑥ Round history list (fills remaining height, like WMP9 playlist) -->
                    <ListBox x:Name="RoundHistoryList"
                             Background="#FF080E18"
                             BorderThickness="0"
                             Foreground="White"
                             FontFamily="{StaticResource WmpChromeFontFamily}"
                             FontSize="10"
                             ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                             VirtualizingPanel.IsVirtualizing="True">
                        <ListBox.ItemContainerStyle>
                            <Style TargetType="ListBoxItem">
                                <Setter Property="Padding" Value="8,3"/>
                                <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                                <Setter Property="Focusable" Value="False"/>
                                <Setter Property="IsHitTestVisible" Value="False"/>
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="ListBoxItem">
                                            <Border x:Name="Bd" Background="Transparent"
                                                    Padding="{TemplateBinding Padding}">
                                                <ContentPresenter/>
                                            </Border>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                            </Style>
                        </ListBox.ItemContainerStyle>
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock x:Name="NameTb" Grid.Column="0"
                                               Text="{Binding BallName}"
                                               Foreground="White"
                                               TextTrimming="CharacterEllipsis"/>
                                    <TextBlock x:Name="TimeTb" Grid.Column="1"
                                               Text="{Binding ElapsedFormatted}"
                                               Foreground="White"
                                               Margin="8,0,0,0"/>
                                    <!-- Fade-in when a record is added or clobbered -->
                                    <Grid.Triggers>
                                        <EventTrigger RoutedEvent="Loaded">
                                            <BeginStoryboard>
                                                <Storyboard>
                                                    <DoubleAnimation Storyboard.TargetProperty="Opacity"
                                                                     From="0" To="1" Duration="0:0:0.4"/>
                                                </Storyboard>
                                            </BeginStoryboard>
                                        </EventTrigger>
                                    </Grid.Triggers>
                                </Grid>
                                <DataTemplate.Triggers>
                                    <DataTrigger Binding="{Binding IsLatest}" Value="True">
                                        <Setter TargetName="NameTb" Property="Foreground" Value="#FFFFD080"/>
                                        <Setter TargetName="TimeTb" Property="Foreground" Value="#FFFFD080"/>
                                    </DataTrigger>
                                </DataTemplate.Triggers>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>

                </DockPanel>
            </Border>
            </Grid> <!-- end side panel wrapper -->
        </Grid>

        <!-- ===== Transport chrome panel (equalizer_left/middle/right from Corona.wms) =====
             Per Corona.wms svEqualizerBottom: the chrome panel background hosts transports
             as a single 136×30 atlas (BUTTONGROUP idiom), not individual sliced buttons.
             Hit-testing is layered via invisible buttons at mapping-color positions.
             Pause is a 30×30 overlay at the play position, not a button swap. -->
        <Grid Grid.Row="2" ClipToBounds="True">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="274"/>  <!-- equalizer_left: transports + volume -->
                <ColumnDefinition Width="*"/>    <!-- equalizer_middle: tiled chrome + custom controls -->
                <ColumnDefinition Width="59"/>   <!-- equalizer_right -->
            </Grid.ColumnDefinitions>

            <!-- ===== Left chrome panel: pixel-positioned per Corona.wms ===== -->
            <Canvas Grid.Column="0" Width="274" Height="60" ClipToBounds="True">
                <!-- Chrome background -->
                <Image Source="pack://application:,,,/Assets/Sprites/equalizer_left.png"
                       Canvas.Left="0" Canvas.Top="0" Width="274" Height="60"
                       Stretch="Fill" RenderOptions.BitmapScalingMode="NearestNeighbor"/>

                <!-- Full transport atlas at (8, 20) per Corona.wms bgTransports -->
                <Image x:Name="TransportsAtlas"
                       Source="pack://application:,,,/Assets/Sprites/transports.png"
                       Canvas.Left="8" Canvas.Top="20" Width="136" Height="30"
                       Stretch="Fill" RenderOptions.BitmapScalingMode="HighQuality"/>

                <!-- Per-button hover/down overlays — clipped to individual button rects -->
                <Image x:Name="TransportsHover"
                       Source="pack://application:,,,/Assets/Sprites/transports_hover.png"
                       Canvas.Left="8" Canvas.Top="20" Width="136" Height="30"
                       Stretch="Fill" RenderOptions.BitmapScalingMode="HighQuality"
                       Visibility="Collapsed" IsHitTestVisible="False"/>
                <Image x:Name="TransportsDown"
                       Source="pack://application:,,,/Assets/Sprites/transports_down.png"
                       Canvas.Left="8" Canvas.Top="20" Width="136" Height="30"
                       Stretch="Fill" RenderOptions.BitmapScalingMode="HighQuality"
                       Visibility="Collapsed" IsHitTestVisible="False"/>

                <!-- Pause overlay — covers play position only, shown when playing -->
                <Image x:Name="PauseOverlay"
                       Source="pack://application:,,,/Assets/Sprites/transports_pause.png"
                       Canvas.Left="8" Canvas.Top="20" Width="30" Height="30"
                       Stretch="Fill" RenderOptions.BitmapScalingMode="HighQuality"
                       Visibility="Collapsed" IsHitTestVisible="False"/>

                <!-- Invisible hit buttons at transports_map.bmp positions (relative to atlas at 8,20) -->
                <Button x:Name="StartStopButton" Canvas.Left="8" Canvas.Top="20"
                        Width="31" Height="30" Opacity="0" Cursor="Hand"
                        ToolTip="Play" Click="StartStopButton_Click"/>
                <Button x:Name="StopButton" Canvas.Left="42" Canvas.Top="25"
                        Width="22" Height="21" Opacity="0" Cursor="Hand"
                        ToolTip="Stop" Click="StopButton_Click"/>
                <Button x:Name="PrevTrackButton" Canvas.Left="69" Canvas.Top="25"
                        Width="22" Height="21" Opacity="0" Cursor="Hand"
                        ToolTip="Previous track" Click="PrevTrackButton_Click"/>
                <Button x:Name="NextTrackButton" Canvas.Left="94" Canvas.Top="25"
                        Width="22" Height="21" Opacity="0" Cursor="Hand"
                        ToolTip="Next track" Click="NextTrackButton_Click"/>

                <!-- MIC toggle at mute position per transports_map.bmp -->
                <ToggleButton x:Name="MicToggle" Canvas.Left="121" Canvas.Top="25"
                              Width="22" Height="21" Opacity="0" Cursor="Hand"
                              ToolTip="Toggle microphone"
                              Checked="MicToggle_Changed" Unchecked="MicToggle_Changed"/>

                <!-- Volume slider at Corona.wms position (150, 25), 68×18 -->
                <Slider x:Name="VolumeSlider" Canvas.Left="150" Canvas.Top="31"
                        Width="68" Height="18" Minimum="0" Maximum="1"
                        SmallChange="0.02" LargeChange="0.1"
                        Style="{StaticResource WmpWedgeVolumeSliderStyle}"
                        ValueChanged="VolumeSlider_ValueChanged"
                        ToolTip="System volume"/>
            </Canvas>

            <!-- ===== Tiled middle chrome + custom controls ===== -->
            <Grid Grid.Column="1">
                <Rectangle RenderOptions.BitmapScalingMode="NearestNeighbor">
                    <Rectangle.Fill>
                        <ImageBrush ImageSource="pack://application:,,,/Assets/Sprites/equalizer_middle.png"
                                    TileMode="Tile" ViewportUnits="Absolute"
                                    Viewport="0,0,1,60" Stretch="Fill"/>
                    </Rectangle.Fill>
                </Rectangle>

                <!-- LIVE indicator + Rain toggle in the chrome mid-section -->
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center"
                            HorizontalAlignment="Left" Margin="12,0,0,0">
                    <TextBlock x:Name="MicLiveCaption"
                               Text="LIVE"
                               FontFamily="{StaticResource WmpChromeFontFamily}"
                               FontSize="9" FontWeight="Bold"
                               Foreground="{StaticResource WmpPlayGlyphBrush}"
                               VerticalAlignment="Center"
                               Visibility="Collapsed">
                        <TextBlock.Effect>
                            <DropShadowEffect Color="{StaticResource WmpPlayAmberColor}"
                                              BlurRadius="6" ShadowDepth="0"/>
                        </TextBlock.Effect>
                    </TextBlock>

                    <ui:ToggleSwitch x:Name="RainToggle" Content="Rain"
                                     VerticalAlignment="Center"
                                     IsChecked="False" Margin="16,0,0,0"
                                     Checked="RainToggle_Changed" Unchecked="RainToggle_Changed"/>
                </StackPanel>
            </Grid>

            <!-- ===== Right chrome panel ===== -->
            <Image Grid.Column="2"
                   Source="pack://application:,,,/Assets/Sprites/equalizer_right.png"
                   Width="59" Height="60" Stretch="None"
                   HorizontalAlignment="Right" VerticalAlignment="Top"
                   RenderOptions.BitmapScalingMode="NearestNeighbor"/>
        </Grid>
    </Grid>
    </Border>
</Window>
